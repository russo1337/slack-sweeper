{
  "manifest_version": 3,
  "name": "Slack Sweeper",
  "version": "1.0.0",
  "description": "Deactivate Slack users from a CSV using your current admin session.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://*.slack.com/api/*"],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "Slack Sweeper",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  }
}
